@startuml
title Athena JS Skill Guidance (After v2.0.0 Refresh)

skinparam backgroundColor White
skinparam defaultFontColor Black
skinparam shadowing false
skinparam RectangleFontColor Black
skinparam ArrowColor Black
skinparam ArrowFontColor Black
skinparam PackageBorderColor Black
skinparam PackageFontColor Black

package "Source Order (Enforced)" #E8F3FF {
  rectangle "1) docs/index.md\n2) docs/getting-started.md\n3) docs/api-reference.md\n4) docs/auth/*.mdx\n5) src/index.ts + src/react/index.ts\n6) CHANGELOG.md" as OrderedSources #DCEBFF
  rectangle "Context7 ID\n/xylex-group/athena-js" as Context7Source #D9F2E6
}

rectangle "Codex Skill\nathena-js (v2.0.0 focused)" as SkillV2 #EAF7FF

package "Guidance Output" #F4F9E9 {
  rectangle "Preferred auth path\ncreateClient(...).auth" as PreferredAuth #D9F2E6
  rectangle "React + query runtime\naligned to current exports" as ReactAligned #FFF2CC
  rectangle "Typed registry + generator\nwith migration guardrails" as TypedGuidance #FFE0B2
  rectangle "Conflict rule\nlocal v2.0.0 docs/exports win\nover stale autogenerated labels" as ConflictRule #FADBD8
}

OrderedSources --> SkillV2
Context7Source --> SkillV2
SkillV2 --> PreferredAuth
SkillV2 --> ReactAligned
SkillV2 --> TypedGuidance
SkillV2 --> ConflictRule

@enduml
