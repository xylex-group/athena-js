@startuml
title Athena JS Skill Guidance (Before v2.0.0 Refresh)

skinparam backgroundColor White
skinparam defaultFontColor Black
skinparam shadowing false
skinparam RectangleFontColor Black
skinparam ArrowColor Black
skinparam ArrowFontColor Black
skinparam PackageBorderColor Black
skinparam PackageFontColor Black

rectangle "Codex Skill\nathena-js (legacy heavy file)" as Skill #FBE5D6

package "Inputs" #E8F3FF {
  rectangle "Mixed docs and snippets\n(no strict source order)" as MixedDocs #DCEBFF
  rectangle "Legacy auth examples\n(createAuthClient + flat methods)" as LegacyAuth #FFD9D9
}

package "Outcomes" #F4F9E9 {
  rectangle "Accurate in many areas\nbut high drift risk" as DriftRisk #FFF2CC
  rectangle "Version confusion\n(v2 package vs older autogenerated labels)" as VersionMismatch #FFE0B2
}

MixedDocs --> Skill
LegacyAuth --> Skill
Skill --> DriftRisk
Skill --> VersionMismatch

@enduml
