{
  "name": "list_customers",
  "description": "List customers in the user's Linear workspace",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "limit": {
        "default": 50,
        "description": "Max results (default 50, max 250)",
        "type": "number",
        "maximum": 250
      },
      "cursor": {
        "description": "Next page cursor",
        "type": "string"
      },
      "orderBy": {
        "default": "updatedAt",
        "description": "Sort: createdAt | updatedAt",
        "type": "string",
        "enum": [
          "createdAt",
          "updatedAt"
        ]
      },
      "query": {
        "description": "Search customer name",
        "type": "string"
      },
      "owner": {
        "description": "User ID, name, email, or \"me\"",
        "type": "string"
      },
      "status": {
        "description": "Customer status name or ID",
        "type": "string"
      },
      "tier": {
        "description": "Customer tier name or ID",
        "type": "string"
      },
      "createdAt": {
        "description": "Created after: ISO-8601 date/duration (e.g., -P1D)",
        "type": "string"
      },
      "updatedAt": {
        "description": "Updated after: ISO-8601 date/duration (e.g., -P1D)",
        "type": "string"
      },
      "includeArchived": {
        "default": false,
        "description": "Include archived items",
        "type": "boolean"
      },
      "includeNeeds": {
        "default": false,
        "description": "Include associated customer needs",
        "type": "boolean"
      }
    },
    "additionalProperties": false
  }
}